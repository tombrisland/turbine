exports[`update-generation > update with mixed plain values and expressions 1`] = `
{
  "ExpressionAttributeNames": {
    "#update_age": "age",
    "#update_createdAt": "createdAt",
    "#update_name": "name",
  },
  "ExpressionAttributeValues": {
    ":age": 1,
    ":createdAt": "2012-02-18T00:00:00.000Z",
    ":name": "Alice",
  },
  "Key": {
    "pk": "user#123",
    "sk": "user@example.com",
  },
  "ReturnValues": "ALL_NEW",
  "TableName": "test-table",
  "UpdateExpression": "SET #update_name = :name, #update_createdAt = if_not_exists(#update_createdAt, :createdAt), #update_age = #update_age + :age",
}
`;

