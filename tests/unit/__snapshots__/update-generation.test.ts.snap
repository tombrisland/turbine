exports[`update-generation > update removes field by setting null 1`] = `
{
  "ExpressionAttributeNames": {
    "#update_age": "age",
    "#update_createdAt": "createdAt",
    "#update_name": "name",
  },
  "ExpressionAttributeValues": {
    ":age": 10,
    ":createdAt": "2012-02-18T00:00:00.000Z",
  },
  "Key": {
    "pk": "user#123",
    "sk": "user@example.com",
  },
  "ReturnValues": "ALL_NEW",
  "TableName": "test-table",
  "UpdateExpression": "SET #update_age = :age, #update_createdAt = if_not_exists(#update_createdAt, :createdAt) REMOVE #update_name",
}
`;

